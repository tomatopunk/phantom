{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Phantom Desktop",
  "version": "0.1.0",
  "identifier": "io.github.tomatopunk.phantom.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Phantom",
        "width": 1400,
        "height": 900,
        "decorations": true,
        "titleBarStyle": "Visible",
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
